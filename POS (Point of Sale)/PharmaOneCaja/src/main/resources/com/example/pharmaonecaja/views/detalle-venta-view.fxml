<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.pharmaonecaja.controller.DetalleController"
      spacing="15"
      style="-fx-padding:20;">

    <Label text="Detalle de Venta"
           style="-fx-font-size:18; -fx-font-weight:bold;"/>

    <TableView fx:id="tablaDetalle">

        <columns>

            <TableColumn fx:id="colProducto"
                         text="Producto"
                         prefWidth="200"/>

            <TableColumn fx:id="colCantidad"
                         text="Cantidad"
                         prefWidth="100"/>

            <TableColumn fx:id="colPrecio"
                         text="Precio"
                         prefWidth="120"/>

            <TableColumn fx:id="colSubtotal"
                         text="Subtotal"
                         prefWidth="120"/>

        </columns>

    </TableView>

    <Label fx:id="lblTotal"
           text="Total: $0.00"
           style="-fx-font-size:16; -fx-font-weight:bold;"/>

</VBox>